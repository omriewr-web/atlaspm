// AtlasPM - Database Schema
// Stack: PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  PM
  COLLECTOR
  OWNER
  BROKER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String    @unique
  passwordHash  String
  role          UserRole  @default(COLLECTOR)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedProperties UserProperty[]
  notes         TenantNote[]
  commLogs      CommLog[]
  payments      Payment[]
  legalNotes    LegalNote[]
  tasks         Task[]
  emails        EmailLog[]
  assignedWorkOrders  WorkOrder[] @relation("WorkOrderAssignee")
  createdWorkOrders   WorkOrder[] @relation("WorkOrderCreator")
  workOrderComments   WorkOrderComment[]
  @@map("users")
}

model UserProperty {
  id         String   @id @default(cuid())
  userId     String
  buildingId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  @@unique([userId, buildingId])
  @@map("user_properties")
}

model Building {
  id             String   @id @default(cuid())
  yardiId        String   @unique
  address        String
  altAddress     String?
  entity         String?
  portfolio      String?
  region         String?
  zip            String?
  block          String?
  lot            String?
  type           String   @default("Residential")
  owner          String?
  ownerEmail     String?
  manager        String?
  arTeam         String?
  apTeam         String?
  headPortfolio  String?
  mgmtStartDate  DateTime?
  einNumber      String?

  // DOB / Registration IDs
  bin            String?  // BIN # (DOB)
  mdrNumber      String?  // MDR Number
  dhcrRegId      String?  // DHCR Registration ID

  // Construction Details
  squareFootage  Int?
  yearBuilt      Int?
  constructionType String?
  floors         Int?
  floorsBelowGround Int?

  // Life Safety Systems (JSON)
  lifeSafety     Json?    // { sprinkler, sprinklerCoverage, fireAlarm, egress, backflow, standpipe, coolingTower, waterStorageTank, petroleumBulkStorage }

  // Elevator Info (JSON)
  elevatorInfo   Json?    // { type, cat1Date, cat5Date, followUpNotes, aocSubmitted }

  // Boiler Info (JSON)
  boilerInfo     Json?    // { lastInspectionDate, device, followUpNotes }

  // Compliance Filing Dates (JSON)
  complianceDates Json?   // { ll152GasPipe, parapetInspection, hpdRegistrationYear, bedBugFilingYear, safetyFilingYear }

  superintendent Json?
  elevatorCompany Json?
  fireAlarmCompany Json?
  utilityMeters  Json?
  utilityAccounts Json?
  totalUnits     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  units          Unit[]
  assignedUsers  UserProperty[]
  importBatches  ImportBatch[]
  workOrders     WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  violations     Violation[]
  complianceItems ComplianceItem[]
  violationSyncLogs ViolationSyncLog[]
  @@map("buildings")
}

model Unit {
  id          String   @id @default(cuid())
  buildingId  String
  unitNumber  String
  unitType    String?
  isVacant    Boolean  @default(false)
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant      Tenant?
  vacancyInfo VacancyInfo?
  workOrders  WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  @@unique([buildingId, unitNumber])
  @@map("units")
}

model Tenant {
  id              String   @id @default(cuid())
  unitId          String   @unique
  yardiResidentId String?  @unique
  name            String
  email           String?
  phone           String?
  marketRent      Decimal  @default(0) @db.Decimal(10, 2)
  legalRent       Decimal  @default(0) @db.Decimal(10, 2)
  dhcrLegalRent   Decimal  @default(0) @db.Decimal(10, 2)
  prefRent        Decimal  @default(0) @db.Decimal(10, 2)
  actualRent      Decimal  @default(0) @db.Decimal(10, 2)
  chargeCode      String?
  isStabilized    Boolean  @default(false)
  deposit         Decimal  @default(0) @db.Decimal(10, 2)
  moveInDate      DateTime?
  leaseExpiration DateTime?
  moveOutDate     DateTime?
  balance         Decimal  @default(0) @db.Decimal(10, 2)
  arrearsCategory String   @default("current")
  arrearsDays     Int      @default(0)
  monthsOwed      Decimal  @default(0) @db.Decimal(5, 1)
  leaseStatus     String   @default("active")
  collectionScore Int      @default(0)
  overrides       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  unit            Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  notes           TenantNote[]
  commLogs        CommLog[]
  payments        Payment[]
  legalCase       LegalCase?
  tasks           Task[]
  emails          EmailLog[]
  workOrders      WorkOrder[]
  @@map("tenants")
}

enum NoteCategory {
  GENERAL
  COLLECTION
  PAYMENT
  LEGAL
  LEASE
  MAINTENANCE
}

model TenantNote {
  id        String       @id @default(cuid())
  tenantId  String
  authorId  String
  text      String       @db.Text
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("tenant_notes")
}

enum CommType {
  PHONE
  EMAIL
  LETTER
  IN_PERSON
  TEXT_MSG
  LEGAL_NOTICE
  OTHER
}

model CommLog {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  type      CommType
  summary   String   @db.Text
  outcome   String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("comm_logs")
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  recordedBy  String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recorder    User     @relation(fields: [recordedBy], references: [id])
  @@index([tenantId, date(sort: Desc)])
  @@map("payments")
}

enum LegalStage {
  NOTICE_SENT
  HOLDOVER
  NONPAYMENT
  COURT_DATE
  STIPULATION
  JUDGMENT
  WARRANT
  EVICTION
  SETTLED
}

model LegalCase {
  id          String     @id @default(cuid())
  tenantId    String     @unique
  inLegal     Boolean    @default(true)
  stage       LegalStage @default(NOTICE_SENT)
  caseNumber  String?
  attorney    String?
  filedDate   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes       LegalNote[]
  @@map("legal_cases")
}

model LegalNote {
  id          String     @id @default(cuid())
  legalCaseId String
  authorId    String
  text        String     @db.Text
  stage       LegalStage
  createdAt   DateTime   @default(now())
  legalCase   LegalCase  @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)
  author      User       @relation(fields: [authorId], references: [id])
  @@index([legalCaseId, createdAt(sort: Desc)])
  @@map("legal_notes")
}

model Task {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String
  type        String
  description String
  dueDate     DateTime?
  done        Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  @@index([tenantId])
  @@index([dueDate])
  @@map("tasks")
}

model VacancyInfo {
  id           String   @id @default(cuid())
  unitId       String   @unique
  condition    String?
  accessType   String?
  accessNotes  String?
  proposedRent Decimal? @db.Decimal(10, 2)
  readyDate    DateTime?
  internalNotes String?  @db.Text
  brokerNotes  Json?
  updatedAt    DateTime @updatedAt
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  @@map("vacancy_info")
}

model DhcrRent {
  id           String   @id @default(cuid())
  buildingId   String
  unitNumber   String
  legalRent    Decimal  @db.Decimal(10, 2)
  regId        String?
  dhcrAddress  String?
  importedAt   DateTime @default(now())
  @@unique([buildingId, unitNumber])
  @@map("dhcr_rents")
}

model ImportBatch {
  id          String   @id @default(cuid())
  buildingId  String?
  filename    String
  format      String
  recordCount Int      @default(0)
  status      String   @default("completed")
  errors      Json?
  importedAt  DateTime @default(now())
  building    Building? @relation(fields: [buildingId], references: [id])
  @@map("import_batches")
}

enum EmailType {
  DEMAND_LETTER
  PAYMENT_REMINDER
  LATE_NOTICE
  COLLECTION_REPORT
  LEASE_RENEWAL
  CUSTOM
}

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String?
  sentById       String
  type           EmailType
  subject        String
  body           String    @db.Text
  recipientEmail String
  status         String    @default("sent")
  sentAt         DateTime  @default(now())
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  sentBy         User      @relation(fields: [sentById], references: [id])
  @@index([tenantId, sentAt(sort: Desc)])
  @@map("email_logs")
}

// ── Work Order & Maintenance ──────────────────────────────────────

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  OTHER
}

enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model Vendor {
  id         String   @id @default(cuid())
  name       String
  company    String?
  email      String?
  phone      String?
  specialty  String?
  hourlyRate Decimal? @db.Decimal(10, 2)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workOrders WorkOrder[]
  complianceItems ComplianceItem[]
  @@map("vendors")
}

model WorkOrder {
  id             String            @id @default(cuid())
  title          String
  description    String            @db.Text
  status         WorkOrderStatus   @default(OPEN)
  priority       WorkOrderPriority @default(MEDIUM)
  category       WorkOrderCategory @default(GENERAL)
  photos         Json?
  estimatedCost  Decimal?          @db.Decimal(10, 2)
  actualCost     Decimal?          @db.Decimal(10, 2)
  scheduledDate  DateTime?
  completedDate  DateTime?
  buildingId     String
  unitId         String?
  tenantId       String?
  vendorId       String?
  assignedToId   String?
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  building       Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit           Unit?             @relation(fields: [unitId], references: [id])
  tenant         Tenant?           @relation(fields: [tenantId], references: [id])
  vendor         Vendor?           @relation(fields: [vendorId], references: [id])
  assignedTo     User?             @relation("WorkOrderAssignee", fields: [assignedToId], references: [id])
  createdBy      User?             @relation("WorkOrderCreator", fields: [createdById], references: [id])
  comments       WorkOrderComment[]
  violations     Violation[]
  @@index([buildingId])
  @@index([status])
  @@index([priority])
  @@map("work_orders")
}

model WorkOrderComment {
  id          String    @id @default(cuid())
  workOrderId String
  authorId    String
  text        String    @db.Text
  photos      Json?
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])
  @@index([workOrderId, createdAt(sort: Desc)])
  @@map("work_order_comments")
}

model MaintenanceSchedule {
  id                 String               @id @default(cuid())
  title              String
  description        String?              @db.Text
  frequency          MaintenanceFrequency
  nextDueDate        DateTime
  autoCreateWorkOrder Boolean             @default(true)
  buildingId         String
  unitId             String?
  building           Building             @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit               Unit?                @relation(fields: [unitId], references: [id])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  @@index([nextDueDate])
  @@map("maintenance_schedules")
}

// ── Compliance & Violations ─────────────────────────────────────

enum ViolationSource {
  HPD
  DOB
  ECB
  FDNY
  DSNY
  DOHMH
  DOB_COMPLAINTS
  HPD_COMPLAINTS
  HPD_LITIGATION
}

enum ViolationClass {
  A
  B
  C
  I
  CLASS1
  CLASS2
  CLASS3
}

enum ViolationSeverity {
  IMMEDIATELY_HAZARDOUS
  HAZARDOUS
  NON_HAZARDOUS
  INFO
}

enum ComplianceCategory {
  LOCAL_LAW
  INSPECTION
  FILING
  CUSTOM
}

enum ComplianceFrequency {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  FIVE_YEAR
  FOUR_YEAR
  ONE_TIME
  ON_EVENT
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PENDING
  OVERDUE
  SCHEDULED
  NOT_APPLICABLE
}

model Violation {
  id                  String            @id @default(cuid())
  buildingId          String
  source              ViolationSource
  externalId          String
  class               ViolationClass?
  severity            ViolationSeverity?
  description         String            @db.Text
  inspectionDate      DateTime?
  issuedDate          DateTime?
  currentStatus       String?
  penaltyAmount       Decimal           @default(0) @db.Decimal(10, 2)
  respondByDate       DateTime?
  certifiedDismissDate DateTime?
  correctionDate      DateTime?
  unitNumber          String?
  novDescription      String?           @db.Text
  hearingDate         DateTime?
  hearingStatus       String?
  linkedWorkOrderId   String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  building            Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  linkedWorkOrder     WorkOrder?        @relation(fields: [linkedWorkOrderId], references: [id])
  complianceItems     ComplianceItem[]
  @@unique([source, externalId])
  @@index([buildingId])
  @@index([source])
  @@index([currentStatus])
  @@index([hearingDate])
  @@index([respondByDate])
  @@map("violations")
}

model ComplianceItem {
  id                String             @id @default(cuid())
  buildingId        String
  type              String
  category          ComplianceCategory
  name              String
  description       String             @db.Text
  dueDate           DateTime?
  frequency         ComplianceFrequency
  status            ComplianceStatus   @default(PENDING)
  lastCompletedDate DateTime?
  nextDueDate       DateTime?
  assignedVendorId  String?
  cost              Decimal            @default(0) @db.Decimal(10, 2)
  filedBy           String?
  certificateUrl    String?
  notes             String?            @db.Text
  linkedViolationId String?
  isCustom          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  building          Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignedVendor    Vendor?            @relation(fields: [assignedVendorId], references: [id])
  linkedViolation   Violation?         @relation(fields: [linkedViolationId], references: [id])
  @@index([buildingId])
  @@index([status])
  @@index([nextDueDate])
  @@index([category])
  @@map("compliance_items")
}

model ViolationSyncLog {
  id           String   @id @default(cuid())
  buildingId   String?
  source       ViolationSource
  syncedAt     DateTime @default(now())
  newCount     Int      @default(0)
  updatedCount Int      @default(0)
  status       String   @default("completed")
  building     Building? @relation(fields: [buildingId], references: [id])
  @@index([buildingId, syncedAt(sort: Desc)])
  @@map("violation_sync_logs")
}